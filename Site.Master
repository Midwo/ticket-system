            </asp:LoginView>
                        <asp:LoginView runat="server" ViewStateMode="Disabled">
                            <AnonymousTemplate>
                                <ul class="nav navbar-nav navbar-right">
                                    <li><a runat="server" href="~/Account/Register">Rejestracja</a></li>
                                    <li><a runat="server" href="~/Account/Login">Logowanie</a></li>
                                </ul>
                            </AnonymousTemplate>
                            <LoggedInTemplate>
                                <ul class="nav navbar-nav navbar-right">
                                    <li><a runat="server" href="~/Account/Manage" title="Manage your account">Ustawienia</a></li>
                                    <li>
                                        <asp:LoginStatus runat="server" LogoutAction="Redirect" LogoutText="Wyloguj" LogoutPageUrl="~/" OnLoggingOut="Unnamed_LoggingOut" />
                                    </li>
                                </ul>
                            </LoggedInTemplate>
                        </asp:LoginView>
                    </div>
            </div>
        </div>
        <div class="container body-content">

           <br/>
    <div class="alert alert-info" role="alert">
  <span class="glyphicon glyphicon-star" aria-hidden="true"></span>
  <span class="sr-only">Error:</span>
  Witaj <%: Context.User.Identity.GetUserName()  %> - dziś jest <%: System.DateTime.Now.ToString("dd-MM-yyyy")  %>. Zapraszam do MD Ticket Sytem.
</div>


            <asp:ContentPlaceHolder ID="MainContent" runat="server">
            </asp:ContentPlaceHolder>
            <hr />
            <footer>
               <asp:Label ID="Label1" runat="server" Visible="False"></asp:Label>
              

                       <div class="row">
  <div class="col-xs-6 col-md-6">

         <p>&copy; <%: DateTime.Now.Year %> - Michał Dwojak</p>
             <address>
        Kontakt: <a href="mailto:michal.dwojak92@gmail.com">michal.dwojak92@gmail.com</a>

    </address>


  </div>
  <div class="col-xs-6 col-md-6">
      
    <asp:HyperLink 
         runat="server" 
         CssClass="btn btn-primary pull-right" 
         Style="margin-left:5px;"
         NavigateUrl="~/PAGE/Regulations">
         Regulamin
    </asp:HyperLink>

    <asp:HyperLink 
         runat="server" 
         CssClass="btn btn-primary pull-right" 
         NavigateUrl="~/PAGE/Policy">
         Polityka prywatności
    </asp:HyperLink>

