                                </ul>
                            </li>

                                <li class="dropdown">
                                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">Szukaj <span class="caret"></span></a>
                                    <ul class="dropdown-menu" role="menu">
                                        <li class="nav-header">Zgłoszenia</li>
                                        
                                        <li><a runat="server" href="~\Page\Szukaj">Szukaj</a></li>
                                    </ul>
                                </li>
                            </ul>
                        </ContentTemplate>
                    </asp:RoleGroup>
                    <asp:RoleGroup Roles="helpdesk">
                        <ContentTemplate>
                          <li class="dropdown"> 
                                <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">Raporty <span class="caret"></span></a>
                                <ul class="dropdown-menu" role="menu">

                                    <li class="nav-header">Zgłoszenia</li>
                                    <li><a  runat="server" href="~\Page\Statusy">Statusy</a></li>
                                    <li class="divider"></li>   
                                    <li class="nav-header">Heldepsk</li>
                                    <li><a runat="server" href="~\Page\Statystki_helpdesku">Statystki helpdesku</a></li>
                                    <li class="divider"></li>   
                                    <li class="nav-header">Konta</li>
                                    <li><a runat="server" href="~\Page\UP0">Uprawnienia poz.0</a></li>
                                    <li><a runat="server" href="~\Page\UP1">Uprawienia poz.1</a></li>
  
                                    <li><a runat="server" href="~\Page\Ostatnia_rejestracja">Ostatnie rejestracje</a></li>
                                </ul>
                            </li>

                                <li class="dropdown">
                                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">Szukaj <span class="caret"></span></a>
                                    <ul class="dropdown-menu" role="menu">
                                        <li class="nav-header">Zgłoszenia</li>
                                        <li><a runat="server" href="~\Page\Szukaj">Szukaj</a></li>
